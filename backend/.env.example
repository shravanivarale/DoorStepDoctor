# ============================================================================
# BACKEND ENVIRONMENT CONFIGURATION
# ============================================================================
# INSTRUCTIONS: Copy this file to .env and replace all PASTE_YOUR_XXX_HERE
# ============================================================================

# ----------------------------------------------------------------------------
# AWS CONFIGURATION
# ----------------------------------------------------------------------------
AWS_REGION=ap-south-1

# ----------------------------------------------------------------------------
# AMAZON BEDROCK (AI/ML)
# ----------------------------------------------------------------------------
# Get from: AWS Console > Bedrock > Knowledge bases
BEDROCK_KB_ID=PASTE_YOUR_KNOWLEDGE_BASE_ID_HERE

# Get from: AWS Console > Bedrock > Guardrails
BEDROCK_GUARDRAIL_ID=PASTE_YOUR_GUARDRAIL_ID_HERE
BEDROCK_GUARDRAIL_VERSION=DRAFT

# Model Configuration
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_MAX_TOKENS=300
BEDROCK_TEMPERATURE=0.2
BEDROCK_TOP_P=0.9

# ----------------------------------------------------------------------------
# DYNAMODB TABLES
# ----------------------------------------------------------------------------
# These table names should match what you created in DynamoDB
DYNAMODB_TRIAGE_TABLE=asha-triage-records
DYNAMODB_USER_TABLE=asha-users
DYNAMODB_ANALYTICS_TABLE=asha-analytics
DYNAMODB_EMERGENCY_TABLE=asha-emergency-cases

# ----------------------------------------------------------------------------
# AWS COGNITO (AUTHENTICATION)
# ----------------------------------------------------------------------------
# Get from: AWS Console > Cognito > User Pools
# MUST BE THE SAME as frontend values
COGNITO_USER_POOL_ID=PASTE_YOUR_USER_POOL_ID_HERE
COGNITO_CLIENT_ID=PASTE_YOUR_CLIENT_ID_HERE
COGNITO_REGION=ap-south-1

# ----------------------------------------------------------------------------
# AMAZON TRANSCRIBE (SPEECH-TO-TEXT)
# ----------------------------------------------------------------------------
TRANSCRIBE_LANGUAGE_CODE=hi-IN
TRANSCRIBE_SAMPLE_RATE=16000
TRANSCRIBE_MEDIA_FORMAT=wav

# ----------------------------------------------------------------------------
# AMAZON POLLY (TEXT-TO-SPEECH)
# ----------------------------------------------------------------------------
POLLY_VOICE_ID=Aditi

# ============================================================================
# NOTES:
# - After filling this file, copy it to .env: cp .env.example .env
# - Never commit .env to git (it's in .gitignore)
# - Cognito values MUST match frontend .env.local
# ============================================================================
